# .streamlit/secrets.toml
# This file is for LOCAL development only.
# On Streamlit Cloud, set these in: App Settings → Secrets
# NEVER commit this file — it is in .gitignore

# Weather API (optional — app runs in demo mode without it)
OPENWEATHER_API_KEY = ""

# PostgreSQL (optional — app runs in demo mode without it)
POSTGRES_HOST = "localhost"
POSTGRES_PORT = "5432"
POSTGRES_USER = "datacenter_user"
POSTGRES_PASSWORD = "your_password_here"
POSTGRES_DB = "datacenter_platform"

# MinIO / S3 (optional)
MINIO_ENDPOINT = "http://localhost:9000"
MINIO_ACCESS_KEY = "minio_admin"
MINIO_SECRET_KEY = "your_minio_password"
